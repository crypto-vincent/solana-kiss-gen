{
  "name": "solana-kiss-gen",
  "version": "0.0.1",
  "bin": {
    "solana-kiss-gen": "./dist/index.js"
  },
  "dependencies": {
    "cli-kiss": "0.2.3",
    "solana-kiss": "0.2.22"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "format": "prettier --write src && prettier --write tests",
    "checks": "tsc --noEmit --skipLibCheck && prettier --check src && prettier --check tests/*.ts",
    "tests": "jest --config jest.config.ts",
    "build": "tsup src/index.ts --dts --clean --minify --sourcemap --out-dir dist"
